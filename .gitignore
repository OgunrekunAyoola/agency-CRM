# .gitignore for Agency CRM (Root)

# --- Environment ---
.env
.env.local
.env.*.local
*.env
# (Explicitly include example files if needed)
!.env.example

# --- .NET (Backend) ---
**/bin/
**/obj/
.dotnet/
**/App_Data/
**/user-secrets.json
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
.vscode/

# --- Node.js / Next.js (Frontend) ---
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/coverage/
.vercel
**/*.tsbuildinfo
**/next-env.d.ts

# --- OS / IDE ---
.DS_Store
Thumbs.db
*.bak
*.tmp
*.temp
.idea/
.project
.settings/

# --- Logs ---
*.log
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Databases ---
**/postgres-data/
*.db
*.sqlite
