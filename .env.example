# ──────────────────────────────────────────────
# Agency CRM — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# ──────────────────────────────────────────────

# ── Database ──
# Local dev uses SQLite automatically (no setup needed).
# Set DATABASE_URL to a PostgreSQL connection string for production (Railway / Supabase).
DATABASE_URL=
# Individual Postgres vars (used if DATABASE_URL is not set)
DB_USER=postgres
DB_PASSWORD=
DB_NAME=postgres
DB_HOST=localhost
DB_PORT=5432

# ── JWT Auth ──
# Must be at least 32 characters. Use a random secret in production.
JWT_KEY=change_me_to_a_random_32_char_secret
JWT_ISSUER=agency_crm
JWT_AUDIENCE=agency_crm
# Access token lifetime in minutes (default: 15)
JWT_EXPIRY_MINUTES=15

# ── CORS ──
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000

# ── Email (SMTP) ──
# Required for forgot-password reset emails to be sent.
# Leave blank in local dev — the reset link will be logged to the console instead.
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@youragency.com
EMAIL_FROM_NAME=Agency CRM

# ── Frontend ──
# URL of the .NET API — used by Next.js server-side rendering.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Used by AuthService to build password-reset links in emails.
FRONTEND_BASE_URL=http://localhost:3000

# ── Environment ──
ASPNETCORE_ENVIRONMENT=Development
API_PORT=8000
WEB_PORT=3000

# ── Hangfire (background jobs) ──
# Uses in-memory storage in dev. Set to a valid Postgres URL in production.
HANGFIRE_CONNECTION_STRING=

# ── Ad Platform Webhooks (optional) ──
# Verify tokens used to authenticate incoming webhook payloads.
META_WEBHOOK_VERIFY_TOKEN=
GOOGLE_WEBHOOK_VERIFY_TOKEN=
TIKTOK_WEBHOOK_VERIFY_TOKEN=
